{
    "manifest_version": 3,
    "name": "Tab Archiver",
    "version": "1.0.0",
    "description": "Archive all open tabs to a history page to save memory.",
    "permissions": [
        "tabs",
        "storage",
        "unlimitedStorage"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Archive Tabs"
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}